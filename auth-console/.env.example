# 复制为 .env.local 按需覆盖
VITE_ADMIN_BASE_URL=            # 空=相对路径,dev 走 vite proxy / prod 走 nginx 同源反代
VITE_ADMIN_TARGET=http://localhost:8201   # 仅 dev proxy 目标(不进产物)
VITE_CASDOOR_AUTHORITY=http://localhost:8000
VITE_CASDOOR_CLIENT_ID=        # Casdoor 的 auth-console 应用 client_id(M2 前置)
VITE_OIDC_SCOPE=openid profile
